rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Visitor Management System - Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Validates student email domain */
    function isStudentEmail() {
      return isSignedIn() && request.auth.token.email.matches('.*@neu\\.edu\\.ph$');
    }

    /** @description Validates admin email domain or specific authorized accounts */
    function isAdminEmail() {
      return isSignedIn() && (
        request.auth.token.email == 'eyamendez18june@gmail.com' || 
        request.auth.token.email == 'jcesperanza@neu.edu.ph'
      );
    }

    /** @description Checks if the user has the 'admin' role in their profile. */
    function isAdmin() {
      return isAdminEmail() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    /** @description Checks if the user's account is active. */
    function isNotBlocked() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked == false;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      // Allow creation for legitimate domains or admin emails
      allow create: if isOwner(userId) && (isStudentEmail() || isAdminEmail());
      // Allow users to update their own profile data (name, email, etc.) but block role/blocking escalation
      allow update: if (isOwner(userId) && 
                      request.resource.data.role == resource.data.role && 
                      request.resource.data.isBlocked == resource.data.isBlocked) 
                   || isAdmin();
      allow delete: if isAdmin();
    }

    match /visitLogs/{visitLogId} {
      allow get: if isAdmin() || (resource != null && resource.data.userId == request.auth.uid);
      // Allow users to list their own logs, but restrict global list to admins
      allow list: if isAdmin() || (request.query.limit <= 100 && request.query.filters.userId == request.auth.uid);
      // Institutional users can create logs if they aren't blocked
      allow create: if (isStudentEmail() || isAdminEmail()) && isNotBlocked() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin(); 
    }

    match /colleges/{collegeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /purposeOfVisits/{purposeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}